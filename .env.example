# Core
ENV=development
LOG_LEVEL=INFO

# Auth (Pocket ID OIDC)
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid profile email
OWNER_OPEN_ID=
JWT_SECRET=change-me-please
SESSION_COOKIE_NAME=tc_session
AUTH_DISABLED=true

# Jobs
JOB_RETENTION_DAYS=30
MAX_UPLOAD_MB=500
MAX_TOTAL_UPLOAD_MB=2048

# Paths — use absolute paths that match the Docker volume mount points
DATA_DIR=/app/data
STORAGE_DIR=/app/storage
